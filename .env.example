# ================================================================
#  VideoGen AI — Variáveis de Ambiente
#  Copia este ficheiro para .env e preenche as tuas chaves
# ================================================================
#
#  CUSTO ZERO com estas 2 chaves gratuitas:
#    1. GROQ_API_KEY   → console.groq.com      (30 seg, sem cartão)
#    2. PEXELS_API_KEY → pexels.com/api         (grátis)
#    + gTTS para voz   → sem chave necessária
#
# ================================================================

# ── AI — escolhe UMA (Groq é a melhor opção grátis) ─────────────

# OPÇÃO A: Groq — Llama 3.3-70B, grátis, ultra rápido
# Regista em https://console.groq.com → API Keys → Create Key
GROQ_API_KEY=

# OPÇÃO B: Google Gemini Flash — também grátis
# Vai a https://aistudio.google.com → Get API Key
GEMINI_API_KEY=

# OPÇÃO C: OpenAI — pago (gpt-4o-mini ~$0.01/video)
OPENAI_API_KEY=

# ── Imagens reais — Pexels (100% grátis) ────────────────────────
# Regista em https://www.pexels.com/api/ → Your API Key
PEXELS_API_KEY=

# ── Voz (opcional — gTTS funciona sem chave) ─────────────────────
# ElevenLabs tem free tier (10k chars/mês)
# https://elevenlabs.io
ELEVENLABS_API_KEY=

# ── Base de dados ────────────────────────────────────────────────
# SQLite por defeito — não precisas de nada extra
# Para produção séria, usa PostgreSQL do Railway:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db
DATABASE_URL=sqlite+aiosqlite:////app/output/videogen.db

# ── Qualidade dos vídeos ─────────────────────────────────────────
VIDEO_QUALITY=medium    # low | medium | high
VIDEOS_PER_RUN=3

# ── Não precisas de mudar isto ───────────────────────────────────
OUTPUT_DIR=/app/output/videos
TEMP_DIR=/app/output/temp
LOG_LEVEL=INFO
