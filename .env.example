# ═══════════════════════════════════════════════════════════
# TikTok Video Generator - Configuração de Ambiente
# Copia para .env e preenche os valores necessários
# ═══════════════════════════════════════════════════════════

# ─── LLM (Script) ─────────────────────────────────────────
# Opção 1: Ollama (recomendado - 100% local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Opção 2: Groq (gratuito, precisa de conta em groq.com)
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# Opção 3: OpenRouter (tem modelos gratuitos)
# OPENROUTER_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxx

# ─── Imagens ──────────────────────────────────────────────
# Stable Diffusion local (AUTOMATIC1111)
SD_USE_LOCAL=false
SD_API_URL=http://127.0.0.1:7860

# Hugging Face (gratuito com conta)
# HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# ─── TTS ──────────────────────────────────────────────────
# Opções: edge-tts, piper, coqui, gtts, auto
TTS_ENGINE=edge-tts

# ─── Aplicação ────────────────────────────────────────────
LOG_LEVEL=INFO
